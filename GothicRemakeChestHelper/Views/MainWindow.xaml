<Window x:Class="GothicRemakeChestHelper.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Konfiguracja Zależności" Height="550" Width="750"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource bg_main}"
        Foreground="{DynamicResource text_primary}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ItemsControl Grid.Row="0" ItemsSource="{Binding segment_headers}" Margin="110,0,0,15">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" FontWeight="Bold" FontSize="16" TextAlignment="Center" Foreground="{DynamicResource text_secondary}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding puzzle_matrix}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding row_label}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding cells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding display_icon}" 
                                            Command="{Binding left_click_command}"
                                            Margin="5,0" Height="36" Padding="0" FontSize="18">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding is_editable}" Value="False">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Background" Value="#121214"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>

                                        <Button.InputBindings>
                                            <MouseBinding MouseAction="RightClick" Command="{Binding right_click_command}"/>
                                        </Button.InputBindings>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Grid.Row="2" Content="Oblicz optymalne rozwiązanie" Command="{Binding calculate_command}" Height="45" Margin="0,25,0,0" FontSize="16" FontWeight="Bold" Background="{DynamicResource accent_color}" Foreground="White"/>
    </Grid>
</Window>