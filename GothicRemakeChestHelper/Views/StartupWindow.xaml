<Window x:Class="GothicRemakeChestHelper.Views.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ustawienia Początkowe" Height="850" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource bg_main}"
        Foreground="{DynamicResource text_primary}">

    <Window.Resources>
        <Style x:Key="circle_selector_style" TargetType="ListBoxItem">
            <Setter Property="Background" Value="{DynamicResource bg_surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource text_secondary}"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="18" BorderBrush="{DynamicResource border_color}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource bg_hover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource accent_color}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource accent_color}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="1. Wybierz liczbę segmentów:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15"/>

        <ListBox Grid.Row="1" ItemsSource="{Binding available_counts}" 
                 SelectedItem="{Binding segment_count}" 
                 ItemContainerStyle="{StaticResource circle_selector_style}"
                 Background="Transparent" BorderThickness="0" Margin="0,0,0,30"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>

        <TextBlock Grid.Row="2" Text="2. Ustaw pozycje startowe:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Hidden">
            <ItemsControl ItemsSource="{Binding starting_positions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="{Binding segment_label}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource text_secondary}" Margin="0,0,0,8"/>

                            <ListBox ItemsSource="{Binding available_letters}" 
                                     SelectedItem="{Binding selected_letter}" 
                                     ItemContainerStyle="{StaticResource circle_selector_style}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="4" Content="Dalej 🡆" Height="45" Margin="0,20,0,0" FontSize="16" Click="next_button_click">
            <Button.Background>
                <SolidColorBrush Color="#0078D4"/>
            </Button.Background>
        </Button>
    </Grid>
</Window>