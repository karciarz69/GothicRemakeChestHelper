<Window x:Class="GothicRemakeChestHelper.Views.StepByStepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tryb Krok po Kroku" Height="340" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource bg_main}"
        Foreground="{DynamicResource text_primary}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding progress_text}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource accent_color}"/>

        <Border Grid.Row="1" Background="{DynamicResource bg_surface}" CornerRadius="12" Margin="0,20" Padding="20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding current_step.move_description}" FontSize="20" FontWeight="Bold" 
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{}{ " FontSize="22" FontWeight="Bold" Foreground="{DynamicResource text_secondary}"/>
                    <ItemsControl ItemsSource="{Binding current_step.letters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding display_text}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="FontSize" Value="22"/>
                                            <Setter Property="Foreground" Value="{DynamicResource text_secondary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding is_changed}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource accent_color}"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text=" }" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource text_secondary}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Następny Krok 🡆" Command="{Binding next_step_command}" Height="45" FontSize="16" FontWeight="Bold" Margin="0,0,15,0" Background="{DynamicResource accent_color}" Foreground="White"/>

            <Button Grid.Column="1" Content="Zamknij" Height="45" Width="100" FontSize="16" Click="close_button_click"/>
        </Grid>
    </Grid>
</Window>